# ─── Plane ─────────────────────────────────────────────
PLANE_DOMAIN=plane.yourdomain.com
SECRET_KEY=
WEB_URL=https://${PLANE_DOMAIN}

# ─── PostgreSQL ────────────────────────────────────────
PGHOST=plane-db
PGPORT=5432
PGDATABASE=plane
PGUSER=plane
PGPASSWORD=

# ─── Redis / Valkey ────────────────────────────────────
REDIS_HOST=plane-redis
REDIS_PORT=6379

# ─── RabbitMQ ──────────────────────────────────────────
RABBITMQ_HOST=plane-rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=plane
RABBITMQ_DEFAULT_PASS=

# ─── MinIO (file storage) ──────────────────────────────
MINIO_ROOT_USER=plane-minio
MINIO_ROOT_PASSWORD=
MINIO_BUCKET_NAME=uploads
AWS_S3_ENDPOINT_URL=http://plane-minio:9000
AWS_ACCESS_KEY_ID=plane-minio
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=uploads
AWS_REGION=us-east-1

# ─── SMTP ───────────────────────────────────────────────
EMAIL_HOST=smtp.yourmailprovider.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@yourdomain.com
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=Plane <noreply@yourdomain.com>

# ─── Ports (internal only — Caddy fronts everything) ───
LISTEN_HTTP_PORT=8080
LISTEN_HTTPS_PORT=8443

# ─── Backup ─────────────────────────────────────────────
BACKUP_RETENTION_DAYS=14
